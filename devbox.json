{
  "packages": [
    "python@3.13",
    "uv@latest",
    "openjdk@17",

    "k3d@latest",
    "kubectl@latest",
    "kubernetes-helm@latest",
    "skaffold@latest",
    "k9s@latest",

    "pulumi@latest",

    "git@latest",
    "curl@latest",
    "rsync@latest",
    "gnumake@latest",
    "psmisc@latest",

    "zsh@latest",
    "oh-my-zsh@latest",
    "ruff@latest",
    "jq@latest"
  ],
  "shell": {
    "init_hook": [
      "echo '🚀 Welcome to AgenticArchitect Development Shell'",
      "echo 'Type \"devbox run\" to see available scripts'"
    ],
    "scripts": {
      "set": "make install && make cluster",
      "up": "fuser -k 8080/tcp || true && skaffold dev --port-forward --tail",
      "test-ci": "make test",
      "ci-clean": "make ci-deep-clean",
      "ci-build": "skaffold build --push=true --file-output=build.json && make ci-tag-latest",
      "ci-deploy": "make ci-fetch-kubeconfig && make ci-deploy",
      "debug-ci": "make debug",
      "infra-reinstall": "make infra-reinstall"
      }
  }
}