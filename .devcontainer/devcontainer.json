{
    /*
   * Prerequisites:
   * 1. Docker and Docker Compose must be installed on your system.
   * 2. VSCode with the "Remote - Containers" extension installed.
   * 3. (re)Build with Ctrl+Shift+P > Remote-Containers: Rebuild Container
   * 4. Ensure the `architect` service in docker-compose.yml has Python and all dependencies installed.
   */
    "name": "AgenticArchitect Dev Container",
    "dockerComposeFile": "../infra/docker-compose.yml",
    "service": "architect",
    "workspaceFolder": "/app",
    "remoteUser": "vscode",
    "containerUser": "vscode",
    "updateRemoteUserUID": true,
    "overrideCommand": true,
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/common-utils:2.5.5": {
            "installZsh": true,
            "configureZshAsDefaultShell": true,
            "installRsync": true
        },
        "ghcr.io/devcontainers/features/java:1": {
            "version": "17"
        },
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "latest",
            "enableNonRootDocker": true
        }
    },
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.testing.pytestEnabled": true,
                "python.testing.unittestEnabled": false,
                "python.testing.pytestArgs": [
                    "tests",
                    "specs"
                ],
                "python.testing.pytestPath": "pytest",
                "python.testing.autoTestDiscoverOnSaveEnabled": true,
                "python.analysis.extraPaths": [
                    "."
                ],
                "python.analysis.typeCheckingMode": "basic",
                "editor.formatOnSave": true,
                "python.formatting.provider": "black",
                /* --- Configuration Notebook/Jupytext --- */
                "jupyter.interactiveWindow.viewMode": "singleColumn",
                "notebook.formatOnSave.enabled": true,
                "workbench.editorAssociations": {
                    "*.ipynb": "jupyter-notebook",
                    "*.lab.py": "jupyter-notebook"
                }
            },
            "extensions": [
                "ms-python.python",
                "ms-python.debugpy",
                "ms-python.pylint",
                "ms-python.black-formatter",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-renderers",
                "ms-toolsai.jupyter-keymap",
                "mwouts.jupytext",
                "jebbs.plantuml",
                "bierner.markdown-mermaid"
            ]
        }
    },
    "forwardPorts": [
        8080,
        6006,
        4317
    ],
    "postCreateCommand": "make setup-dev"
}