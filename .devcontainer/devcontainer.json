{
    /*
   * Prerequisites:
   * VSCodium with the "jeanp413.open-remote-ssh" extension installed.
   */
    "name": "TheArchitect-Kernel",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "remoteUser": "vscode",
    "workspaceFolder": "/workspaces/AgenticArchitect",

    "features": {
        "ghcr.io/jetpack-io/devbox-feature/devbox:latest": {},
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "moby": false
        }
    },

    "containerEnv": {
        "KUBECONFIG": "/home/vscode/.kube/config"
    },

    "postCreateCommand": "devbox run set",
    "postAttachCommand": "devbox run up",

    "customizations": {
        "devpod": { "ide": "codium" },
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.debugpy",
                "charliermarsh.ruff",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-renderers",
                "marimo-team.vscode-marimo", 
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "ms-azuretools.vscode-docker",
                "stateful.runme",
                "eamodio.gitlens",
                "jebbs.plantuml",
                "bierner.markdown-mermaid"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/bin/python3",
                "python.testing.pytestEnabled": true,
                "terminal.integrated.defaultProfile.linux": "zsh"
            }
        }
    }
}