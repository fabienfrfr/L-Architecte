{
    /*
   * Prerequisites:
   * 1. Docker and Docker Compose must be installed on your system.
   * 2. VSCode with the "Remote - Containers" extension installed.
   * 3. The project must be built at least once with `docker compose -f infra/services/docker-compose.yml build`.
   * 4. Ensure the `architect` service in docker-compose.yml has Python and all dependencies installed.
   */
    "name": "AgenticArchitect Dev Container",
    "dockerComposeFile": "infra/services/docker-compose.yml", // Requires Docker Compose setup
    "service": "architect",
    "workspaceFolder": "/app",
    "settings": {
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "python.formatting.provider": "black",
        "python.testing.pytestEnabled": true,
        "python.analysis.typeCheckingMode": "basic"
    },
    "extensions": [
        "ms-python.python", // Core Python support
        "ms-python.pylint", // Linting
        "ms-python.black-formatter" // Formatting
    ],
    "forwardPorts": [
        8080,
        6006,
        4317
    ], // Architect, Phoenix, OTLP ports
    "postCreateCommand": "pip install -e .",
    // Required for debugging (development only)
    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined"
    ]
}