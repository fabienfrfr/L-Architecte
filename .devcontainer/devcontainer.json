{
    /*
   * Prerequisites:
   * VSCodium with the "jeanp413.open-remote-ssh" extension installed.
   */
    "name": "TheArchitect-Kernel",
    "image": "jetpackio/devbox:latest",
    "remoteUser": "devbox",
    "forwardPorts": [8080, 6006, 2718, 11434],
    "workspaceFolder": "/workspaces/AgenticArchitect",

    // k3s management
    "runArgs": [
        "--add-host=host.k3d.internal:host-gateway"
    ],
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "version": "latest",
            "enableNonRootDocker": "true",
            "moby": false
        }
    },
    "mounts": [
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    ],
    "containerEnv": {
        "DOCKER_HOST": "unix:///var/run/docker.sock",
        "KUBECONFIG": "/home/devbox/.kube/config",
        "KUBERNETES_MASTER": "http://host.docker.internal:6443"
    },

    // DevBox Command
    "postCreateCommand": "devbox run set",
    "postAttachCommand": "devbox run up",

    // IDE
    "customizations": {
        "devpod": {
            "ide": "codium"
        },
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.debugpy",
                "charliermarsh.ruff",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-renderers",
                "marimo-team.vscode-marimo", 
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "ms-azuretools.vscode-docker",
                "stateful.runme",
                "eamodio.gitlens",
                "jebbs.plantuml",
                "bierner.markdown-mermaid"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh",
                "terminal.integrated.profiles.linux": {
                    "zsh": {
                        "path": "/usr/bin/zsh" 
                    }
                },
                "python.defaultInterpreterPath": "/usr/bin/python3", 
                "python.terminal.activateEnvInSelectedTerminal": true,
                "python.testing.pytestEnabled": true,
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff",
                    "editor.formatOnSave": true
                }
            }
        }
    }
}