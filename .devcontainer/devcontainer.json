{
    /*
   * Prerequisites:
   * 1. Docker and Docker Compose must be installed on your system.
   * 2. VSCode with the "Remote - Containers" extension installed.
   * 3. (re)Build with Ctrl+Shift+P > Remote-Containers: Rebuild Container
   * 4. Ensure the `architect` service in docker-compose.yml has Python and all dependencies installed.
   */
    "name": "AgenticArchitect Dev Container",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    "remoteUser": "vscode",
    "containerUser": "vscode",
    "updateRemoteUserUID": true,
    "overrideCommand": true,
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true,
            "configureZshAsDefaultShell": true,
            "installRsync": true
        },
        "ghcr.io/devcontainers/features/java:1": {
            "version": "17"
        },
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
            "version": "latest"
        },
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "version": "latest",
            "moby": false,
            "installDockerBuildx": true,
            "enableNonRootDocker": true
        }
    },
    "mounts": [
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
        "source=${localEnv:HOME}/.kube,target=/home/vscode/.kube,type=bind"
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.testing.pytestEnabled": true,
                "python.testing.unittestEnabled": false,
                "python.testing.pytestArgs": ["tests"],
                "python.testing.autoTestDiscoverOnSaveEnabled": true,
                "python.analysis.extraPaths": ["."],
                "editor.formatOnSave": true,
                "python.formatting.provider": "black"
            },
            "extensions": [
                "ms-python.python",
                "ms-python.black-formatter",
                "googlecloudtools.cloudcode",
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "marimo-team.vscode-marimo",
                "stateful.runme",
                "bierner.markdown-mermaid"
            ]
        }
    },
    "forwardPorts": [8080, 6006, 4317],
    // Prep Infra + Setup App
    "postCreateCommand": "bash infra/k3d-deploy.sh && make setup-dev",
    // Auto-start development loop on every container start
    "postStartCommand": "skaffold dev --cleanup=false"
}