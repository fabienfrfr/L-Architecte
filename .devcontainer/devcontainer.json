{
    /*
   * Prerequisites:
   * 1. Docker must be installed on your system.
   * 2. VSCode with the "Remote - Containers" extension installed.
   * 3. (re)Build with Ctrl+Shift+P > Remote-Containers: Rebuild Container
   */
    "name": "TheArchitect Control Plane",
    "image": "mcr.microsoft.com/devcontainers/python:3.13-bookworm",
    // "initializeCommand": "./infra/setup-k3d-cluster.sh", // k3d doit etre lancé en dehors de devcontainer, (mais aussi skaffold ?)
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true,
            "configureZshAsDefaultShell": true,
            "installRsync": true
        },
        "ghcr.io/devcontainers/features/java:1": {
            "version": "17"
        },
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "moby": false,
            "installDockerBuildx": true
        },
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
            "version": "latest"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.debugpy",
                "ms-python.pylint",
                "ms-python.black-formatter",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-renderers",
                "ms-toolsai.jupyter-keymap",
                "eamodio.gitlens",
                "marimo-team.vscode-marimo",
                "stateful.runme",
                "jebbs.plantuml",
                "bierner.markdown-mermaid",
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "ms-azuretools.vscode-docker"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/bin/python3",
                "python.testing.pytestEnabled": true
            }
        }
    },
    "mounts": [
        "source=${localEnv:HOME}/.kube,target=/home/vscode/.kube,type=bind"
    ],
    "forwardPorts": [8080, 6006, 2718],
    // ajouter l'installation de skaffold, (mais aussi lancer le "dev" et automatiser l'attach avec kubernetes pour les tests ?)
    //"postCreateCommand": "curl -Lo skaffold https://storage.googleapis.com/skaffold/releases/latest/skaffold-linux-amd64 && sudo install skaffold /usr/local/bin/ && sudo chown -R vscode:vscode /home/vscode/.kube",
    //"postStartCommand": "skaffold dev --port-forward & ./scripts/bridge.sh &",
    "remoteUser": "vscode"
}